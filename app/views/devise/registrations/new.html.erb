<h2 style="
  text-align:center;
  font-family:Arial;
  margin-bottom:20px;
  color:#1f2937;
">
  Sign Up
</h2>

<div style="
  width:420px;
  margin:0 auto;
  padding:25px;
  border:1px solid #ddd;
  border-radius:8px;
  background:#f9f9f9;
  font-family:Arial;
">

<%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>

<%= render "devise/shared/error_messages", resource: resource %>

<!-- NAME -->
<div style="margin-bottom:15px;">
  <%= f.label :name, style: "font-weight:bold; display:block; margin-bottom:5px;" %>
  <%= f.text_field :name,
      style: "width:100%; padding:8px; border:1px solid #ccc; border-radius:4px;" %>
</div>

<!-- EMAIL -->
<div style="margin-bottom:15px;">
  <%= f.label :email, style: "font-weight:bold; display:block; margin-bottom:5px;" %>
  <%= f.email_field :email,
      autofocus: true,
      autocomplete: "email",
      style: "width:100%; padding:8px; border:1px solid #ccc; border-radius:4px;" %>
</div>

<!-- PASSWORD -->
<div style="margin-bottom:15px;">
  <%= f.label :password, style: "font-weight:bold; display:block;" %>

  <% if @minimum_password_length %>
    <span style="font-size:12px; color:#6b7280;">
      (<%= @minimum_password_length %> characters minimum)
    </span>
  <% end %>

  <%= f.password_field :password,
      autocomplete: "new-password",
      style: "width:100%; padding:8px; margin-top:5px; border:1px solid #ccc; border-radius:4px;" %>
</div>

<!-- PASSWORD CONFIRM -->
<div style="margin-bottom:20px;">
  <%= f.label :password_confirmation, style: "font-weight:bold; display:block; margin-bottom:5px;" %>
  <%= f.password_field :password_confirmation,
      autocomplete: "new-password",
      style: "width:100%; padding:8px; border:1px solid #ccc; border-radius:4px;" %>
</div>

<!-- SUBMIT -->
<div style="text-align:center;">
  <%= f.submit "Sign up",
      style: "background:#2563eb; color:white; padding:10px 30px; border:none; border-radius:5px; cursor:pointer; font-size:15px;" %>
</div>          

<% end %>

  <!-- LINKS -->

  <div style="text-align:center; margin-top:15px;">
    <%= render "devise/shared/links" %>
  </div>

</div>

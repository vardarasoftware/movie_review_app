<h1>New Comment<h1>
    <%= form_with model: @comment do |form|%>
    <div>
        <%=form.label :body%>
        <%=form.text_field :body%>
    </div>
    <div>
        <%=form.label :user_id%>
        <%=form.text_field :user_id%>
    </div>
    <div>
        <%=form.label :movie_id%>
        <%=form.text_field :movie_id%>
    <%= form.submit "Create Comment"%>
    <%= link_to "Back", comments_path%>
    <%end%>
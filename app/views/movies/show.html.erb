<div class="movie-hero">
  <div class="movie-hero-media">
    <% if @movie.banner.attached? %>
      <%= image_tag @movie.banner, alt: @movie.title, class: "movie-hero-img" %>
    <% elsif @movie.banner_url.present? %>
      <%= image_tag @movie.banner_url, alt: @movie.title, class: "movie-hero-img", onerror: "this.onerror=null;this.src='#{asset_path('placeholder_poster.png')}'" %>
    <% else %>
      <%= image_tag "placeholder_poster.png", alt: "No image", class: "movie-hero-img" %>
    <% end %>
    <div class="movie-hero-gradient"></div>
    <div class="movie-hero-content">
      <h1 class="movie-hero-title"><%= @movie.title %></h1>
      <div class="movie-hero-meta">
        <% if @movie.release_date.present? %>
          <span class="badge"><%= @movie.release_date.year %></span>
        <% end %>
        <% if @movie.genres.loaded? || @movie.genres.exists? %>
          <% @movie.genres.limit(3).pluck(:name).each do |g| %>
            <span class="badge badge-outline"><%= g %></span>
          <% end %>
        <% end %>
        <span class="badge badge-rating">⭐ <%= (@movie.average_rating || 0).to_f.round(1) %> (<%= (@movie.ratings_count || 0).to_i %>)</span>
      </div>
    </div>
  </div>
</div>

<section class="movie-details">
  <div class="movie-details-grid">
    <div class="movie-details-main">
      <h2>Overview</h2>
      <div class="prose"><%= simple_format(@movie.description) %></div>

      <h2 style="margin-top:16px">Comments</h2>
      <div>
        <% @movie.comments.order(created_at: :desc).each do |comment| %>
          <div class="definition-list" style="margin:8px 0;">
            <div class="definition-item">
              <dt><%= comment.user.name.presence || comment.user.email %></dt>
              <dd><%= comment.content %></dd>
            </div>
          </div>
        <% end %>
      </div>

      <% if user_signed_in? %>
        <%= form_with model: [@movie, Comment.new], local: true do |f| %>
          <div class="definition-list" style="padding:12px; margin-top:8px;">
            <div class="definition-item" style="grid-template-columns:120px 1fr; align-items:start;">
              <dt>Your comment</dt>
              <dd><%= f.text_area :content, rows: 3, required: true, style: "width:100%" %></dd>
            </div>
            <div style="text-align:right; margin-top:8px;">
              <%= f.submit "Post Comment", class: "btn" %>
            </div>
          </div>
        <% end %>
      <% else %>
        <p><%= link_to "Sign in", new_user_session_path %> to comment.</p>
      <% end %>
    </div>
    <aside class="movie-details-aside">
      <dl class="definition-list">
        <div class="definition-item">
          <dt>Release date</dt>
          <dd><%= @movie.release_date || '-' %></dd>
        </div>
        <div class="definition-item">
          <dt>Director</dt>
          <dd><%= @movie.director.presence || '-' %></dd>
        </div>
        <div class="definition-item">
          <dt>Writer</dt>
          <dd><%= @movie.writer.presence || '-' %></dd>
        </div>
      </dl>
      <div class="movie-actions">
        <%= link_to "Back to Movies", movies_path, class: "btn" %>
        <% if user_signed_in? %>
          <%= form_with model: [@movie, Rating.new], local: true, html: { style: "display:inline-block; margin-left:8px;" } do |f| %>
            <%= f.number_field :rating, in: 1..5, step: 1, required: true, style: "width:64px;" %>
            <%= f.submit "Rate", class: "btn" %>
          <% end %>
        <% else %>
          <p style="margin-top:8px"><%= link_to "Sign in", new_user_session_path %> to rate.</p>
        <% end %>
      </div>
    </aside>
  </div>
</section>
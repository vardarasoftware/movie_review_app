<h1>Movie Details<h1>
    <div>
        <% if @movie.avatar.attached?%>
        <%= image_tag @movie.avatar, style: "width: 550px; height: 700px; object-fit: cover;"%>
    </div>
    <strong>Title :</strong>
    <%=@movie.title%><br>
    <strong>Discription :</strong>
    <%=@movie.discription%><br>
    <strong>Genre :</strong>
    <%=@movie.genre_id%><br>
    <%= link_to "Back", movies_path%>
    <%end%>
    
<h1>Movies<h1>
    <table>
        <thead>
            <tr>
                <th>Title</th>
                <th>Description</th>
            </tr>
        </thead>
        <tbody>
        <% @movies.each do |movie|%>
        <tr>
            <td><%=movie.title%></td>
            <td><%=movie.discription%></td>
        </tr>
        <%end%>
        </tbody>
        </table>
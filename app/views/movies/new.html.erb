<h1 class="form-title">🎬 New Movie</h1>

<div class="form-container colorful-card">
  <%= form_with model: @movie, local: true do |form| %>

    <div class="form-group">
      <%= form.label :avatar, class: "form-label" %>
      <%= form.file_field :avatar, class: "form-input-file" %>
      <small class="form-hint">Upload a movie poster (JPG/PNG)</small>
    </div>

    <div class="form-group">
      <%= form.label :title, class: "form-label" %>
      <%= form.text_field :title, class: "form-input", placeholder: "Enter movie title" %>
    </div>

    <div class="form-group">
      <%= form.label :description, class: "form-label" %>
      <%= form.text_area :description, class: "form-textarea", placeholder: "Short description of the movie" %>
    </div>

    <div class="form-group">
      <%= form.label :author, class: "form-label" %>
      <%= form.text_field :author, class: "form-input", placeholder: "Author name" %>
    </div>

    <div class="form-group">
      <%= form.label :writer, class: "form-label" %>
      <%= form.text_field :writer, class: "form-input", placeholder: "Writer name" %>
    </div>

    <div class="form-group">
      <%= form.label :genre_id, "Genre", class: "form-label" %>
      <%= form.collection_select :genre_id, Genre.all, :id, :name,
            { prompt: "Select Genre" },
            { class: "form-select" } %>
    </div>

    <div class="form-actions">
      <%= form.submit "Create Movie", class: "btn-submit btn-primary" %>
      <%= link_to "Back", movies_path, class: "back-link" %>
    </div>

  <% end %>
</div>

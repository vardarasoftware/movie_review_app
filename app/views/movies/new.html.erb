<h1>New Movie<h1>
    <%= form_with model: @movie do |form|%>
    <div>
        <%=form.label :title%>
        <%=form.text_field :title%>
    </div>
    <div>
        <%=form.label :discription%>
        <%=form.text_field :discription%>
    </div>
    <%= form.submit "Create Movie"%>
    <%= link_to "Back", movies_path%>
    <%end%>
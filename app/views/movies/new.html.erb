<h1>New Movie<h1>
    <%= form_with model: @movie do |form|%>
    <div>
        <%=form.label :avatar%>
        <%=form.file_field :avatar%>
    </div>
    <div>
        <%=form.label :title%>
        <%=form.text_field :title%>
    </div>
    <div>
        <%=form.label :description%>
        <%=form.text_field :description%>
    </div>
    <div>
        <%= form.label :genre%>
        <%= form.text_field :genre_id%>
    </div>
    <%= form.submit "Create Movie"%>
    <%= link_to "Back", movies_path%>
    <%end%>
<h1 class="form-title">Edit Movie</h1>

<div class="form-container">
  <%= form_with model: @movie, local: true do |form| %>

    <div class="form-group">
      <%= form.label :avatar, class: "form-label" %>
      <%= form.file_field :avatar, class: "form-input-file" %>
    </div>

    <div class="form-group">
      <%= form.label :title, class: "form-label" %>
      <%= form.text_field :title, class: "form-input" %>
    </div>

    <div class="form-group">
      <%= form.label :description, class: "form-label" %>
      <%= form.text_field :description, class: "form-input" %>
    </div>

    <div class="form-group">
      <%= form.label :author, class: "form-label" %>
      <%= form.text_field :author, class: "form-input" %>
    </div>

    <div class="form-group">
      <%= form.label :writer, class: "form-label" %>
      <%= form.text_field :writer, class: "form-input" %>
    </div>

    <div class="form-group">
      <%= form.label :genre_id, "Genre", class: "form-label" %>
      <%= form.collection_select :genre_id, Genre.all, :id, :name, { prompt: "Select Genre" }, { class: "form-select" } %>
    </div>

    <div class="form-actions">
      <%= form.submit "Update Movie", class: "btn-submit" %>
      <%= link_to "Back", movies_path, class: "back-link" %>
    </div>

  <% end %>
</div>

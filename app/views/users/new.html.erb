<h1>New User<h1>
    <%= form_with model: @user do |form|%>
    <div>
        <%=form.label :name%>
        <%=form.text_field :name%>
    </div>
    <div>
        <%=form.label :email%>
        <%=form.email_field :email%>
    </div>
    <%= form.submit "Create User"%>
    <%= link_to "Back", users_path%>
    <%end%>
<div class="user-page">

  <h1 class="user-title">User Details</h1>

  <div class="user-card">
    <div class="user-info">
      <p><strong>Name:</strong> <span class="user-text"><%= @user.name %></span></p>
      <p><strong>Email:</strong> <span class="user-text"><%= @user.email %></span></p>
    </div>

    <div class="user-actions">
      <%= link_to "Edit Profile", edit_user_path(@user), class: "btn btn-primary" %>
    </div>
  </div>

  <hr class="divider">

  <h2 class="section-title">All Reviews by <%= @user.name || "User" %></h2>

  <% if @reviews.present? %>
    <div class="reviews-list">
      <% @reviews.each do |review| %>
        <div class="review-card">
          <p class="review-movie"><strong>Movie:</strong> <%= review.movie.title %></p>
          <p class="review-body"><strong>Review:</strong> <%= review.body %></p>

          <% if user_signed_in? && review.user == current_user %>
            <div class="review-actions">
              <%= link_to "Delete",
                    movie_review_path(review.movie, review),
                    data: { turbo_method: :delete, turbo_confirm: "Delete review?" },
                    class: "action-link delete-link" %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="empty-state">No reviews yet.</p>
  <% end %>

  <hr class="divider">

  <h2 class="section-title">All Ratings by <%= @user.name || "User" %></h2>

  <% if @ratings.present? %>
    <div class="ratings-list">
      <% @ratings.each do |rating| %>
        <div class="rating-card">
          <p class="rating-movie"><strong>Movie:</strong> <%= rating.movie.title %></p>
          <p class="rating-value">
            <strong>Rating:</strong>
            <span class="rating-stars"><%= "⭐" * rating.rating.to_i %></span>
          </p>

          <% if user_signed_in? && rating.user == current_user %>
            <div class="rating-actions">
              <%= link_to "Delete",
                    movie_rating_path(rating.movie, rating),
                    data: { turbo_method: :delete, turbo_confirm: "Delete rating?" },
                    class: "action-link delete-link" %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="empty-state">No ratings yet.</p>
  <% end %>

  <div class="page-footer">
    <%= link_to "Back", movies_path, class: "back-link" %>
  </div>

</div>

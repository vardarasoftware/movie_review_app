<h1>User Details<h1>
    <p>
        <strong>Name</strong>
        <%=@user.name%>
    </p>
    <p>
        <strong>Email</strong>
        <%=@user.email%>
    </p>
    <p>
        <% if @user.avatar.attached?%>
        <%= image_tag @user.avatar%>
        <%end%>
    </p>
    <%= link_to "Back", users_path%>
    
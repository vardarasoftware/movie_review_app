<h1>Movies</h1>

<div>
  <%= link_to "Logout", destroy_user_session_path, data: { turbo_method: :delete } %>
</div>

<br>

<div>
  <%= link_to "New Movie", new_movie_path %>
</div>

<br><br>

  <thead>
    <tr>
      <th>Title</th>
      <th>Description</th>
      <th>Avatar</th>
      <th>Rating</th>
      <th>Actions</th>
    </tr>
  </thead>

  <tbody>
    <% @movies.each do |movie| %>
      <tr>

        <td>
          <%= movie.title %>
        </td>

        <td>
          <%= movie.discription %>
        </td>

        <td>
          <% if movie.avatar.attached? %>
            <%= image_tag movie.avatar.variant(resize_to_limit: [120, 120]) %>
          <% else %>
            No Image
          <% end %>
        </td>

        <td>
          <% if movie.average_rating.present? %>
            <%= "⭐" * movie.average_rating.to_i %>
          <% else %>
            Not rated
          <% end %>
        </td>

        <td>
          <%= link_to "Show", movie %>
        </td>

        <td>
          <%= link_to "Edit", edit_movie_path(movie) %>
        </td>

        <td>
          <%= link_to "Delete", movie,
                data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %>
        </td>

      </tr>
    <% end %>
  </tbody>
</table>

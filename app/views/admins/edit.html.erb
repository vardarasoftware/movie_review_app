<h1>Edit Movie<h1>
<%= form_with model: @movie do |form|%>
<div>
    <%=form.label :Avatar%>
    <%=form.file_field :avatar%>
</div>
<div>
    <%= form.label :title %>
    <%= form.text_field :title %>
</div>
<div>
    <%= form.label :discription %>
    <%= form.text_field :discription%>
</div>
<div>
    <%= form.label :genre %>
    <%= form.text_field :genre_id%>
</div>
<div>
    <%= form.label :rating %>
    <%= form.label :rating, "Rating(1-5)" %>
</div>
<%=form.submit "Update Movie"%>
<%= link_to "Back", admins_path%>
<%end%>
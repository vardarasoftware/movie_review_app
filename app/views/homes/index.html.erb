<div>
  <div>
     Movie Review App
  </div>

  <div>
    <% if user_signed_in? %>

      <span>
        Welcome,
        <strong><%= current_user.name %></strong>
      </span>

      <%= link_to "Logout",
          destroy_user_session_path,
          data: { turbo_method: :delete } %>

    <% else %>

      <%= link_to "Sign Up", new_user_registration_path %>
      <%= link_to "Login", new_user_session_path %>

    <% end %>
  </div>
</div>

<hr>

<h1>Movies</h1>


<table>
  <thead>
    <tr>
      <th>Title</th>
      <th>Description</th>
      <th>Rating</th>
      <th>Latest Review</th>
      <th>Poster</th>
    </tr>
  </thead>

  <tbody>
    <% @movies.each do |movie| %>
      <tr>

        <td>
          <%= movie.title %>
        </td>

        <td>
          <%= movie.description %>
        </td>

        <td>
          <% if movie.average_rating.present? %>
            <%= "⭐" * movie.average_rating.to_i %>
          <% else %>
            No rating
          <% end %>
        </td>
        </td>


        <td>
          <%= movie.reviews.last&.body || "No comments yet" %>
        </td>

        <td>
          <% if movie.avatar.attached? %>
            <%= image_tag movie.avatar.variant(resize_to_limit: [110, 110]) %>
          <% else %>
            No Image
          <% end %>
        </td>

      </tr>
    <% end %>
  </tbody>
</table>

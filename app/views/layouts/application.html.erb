<!DOCTYPE html>
<html>
  <head>
    <title>MovieReviewApp</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if notice.present? %>

  <p class="signin">
    <%= notice %>
  </p>
<% end %>

<nav class="navbar">
  <div class="navbar-left">
    <span class="brand"> Movie Review App</span>
  </div>
  <%= link_to "Movies", movies_path, class: "btnn btn-outline" %>

  <div class="navbar-right">
    <% if user_signed_in? %>
      <%= link_to "My Profile", current_user, class: "btn btn-outline" %>
      <%= link_to "Logout",
        destroy_user_session_path,
        data: { turbo_method: :delete },
        class: "nav-link logout-link" %>
    <% else %>
      <%= link_to "Login", new_user_session_path, class: "nav-link" %>
      <%= link_to "Sign Up", new_user_registration_path, class: "nav-link signup-link" %>
    <% end %>
  </div>
</nav>

<% if alert.present? %>

  <p class="signout">
    <%= alert %>
  </p>
<% end %>
    <%= yield %>
  </body>
</html>

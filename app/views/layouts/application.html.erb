<!DOCTYPE html>
<html>
  <head>
    <title>MovieReviewApp</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <% if controller_path.start_with?("admin/") || controller_path == "admin_sessions" %>
      <%= stylesheet_link_tag "admin", "data-turbo-track": "reload" %>
    <% end %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="site-header">
      <div class="container">
        <a href="<%= root_path %>" class="brand">Movie Review</a>
        <nav class="site-nav">
          <%= link_to "Movies", movies_path, class: "nav-link" %>
          <% if user_signed_in? %>
            <span class="nav-link">Hi, <%= current_user.name.presence || current_user.email %></span>
            <%= button_to "Logout", destroy_user_session_path, method: :delete, class: "nav-link", form: { style: "display:inline" } %>
          <% else %>
            <%= link_to "Sign In", new_user_session_path, class: "nav-link" %>
            <%= link_to "Sign Up", new_user_registration_path, class: "nav-link" %>
          <% end %>
        </nav>
      </div>
    </header>

    <main class="site-main">
      <div class="container">
        <% if notice %>
          <div class="flash notice"><%= notice %></div>
        <% end %>
        <% if alert %>
          <div class="flash alert"><%= alert %></div>
        <% end %>
        <%= yield %>
      </div>
    </main>
  </body>
</html>

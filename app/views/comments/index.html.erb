<h1>List of comments</h1>
<table>
    <thead>
        <tr>
            <th>Body :</th>
            <th>User_id :</th>
            <th>Movie_id :</th>
        </tr>
    </thead>
    <tbody>
        <% @comments.each do |comment| %>
        <tr>
            <td><%=comment.body%></td>
            <td><%=comment.user_id%></td>
            <td><%=comment.movie_id%></td>
        </tr>
    </tbody>
    <%end%>
</table>